---
// Standalone game page — no site layout.
// <style is:global> prevents Astro from scoping CSS selectors, which would
// break classes added dynamically by renderScorecard() and setupDice().
// <script is:inline> keeps game logic in global scope for button event listeners.
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yahtzee | hoofay.com</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    /* ── Design tokens (matching hoofay.com) ── */
    :root {
      --color-games:          #00F5FF;
      --color-games-dim:      #00C4CC;
      --color-surface:        #0A0A0F;
      --color-surface-raised: #12121A;
      --color-surface-card:   #1A1A26;
      --color-surface-border: #2A2A3D;
      --color-text-primary:   #F0F0FF;
      --color-text-secondary: #9090B0;
      --color-text-muted:     #505070;
      --color-amber:          #FFB700;
      --font-sans:  'Inter', system-ui, sans-serif;
      --font-pixel: 'Press Start 2P', monospace;
      --font-mono:  'JetBrains Mono', 'Fira Code', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background-color: var(--color-surface);
      color: var(--color-text-primary);
      font-family: var(--font-sans);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-bottom: 50px;
      user-select: none;
    }

    /* Subtle grid overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(42,42,61,0.35) 1px, transparent 1px),
        linear-gradient(90deg, rgba(42,42,61,0.35) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    body > * { position: relative; z-index: 1; }

    /* ── Nav bar ── */
    #site-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      width: 100%;
      border-bottom: 1px solid var(--color-surface-border);
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    #site-nav .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    #site-nav .logo {
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }

    #site-nav .logo-word {
      font-family: var(--font-pixel);
      font-size: 0.75rem;
      color: var(--color-games);
      text-shadow: 0 0 12px rgba(0,245,255,0.6);
      letter-spacing: 0.05em;
      line-height: 1.6;
      animation: flicker 4s linear infinite;
    }

    #site-nav .logo-tld {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    #site-nav .back-link {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--color-text-secondary);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 6px;
      border: 1px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }

    #site-nav .back-link:hover {
      color: var(--color-games);
      border-color: rgba(0,245,255,0.3);
    }

    @keyframes flicker {
      0%, 95%, 100% { opacity: 1; }
      96%           { opacity: 0.8; }
      97%           { opacity: 1; }
      98%           { opacity: 0.6; }
      99%           { opacity: 1; }
    }

    /* ── Page wrapper ── */
    #page {
      width: 100%;
      max-width: 520px;
      padding: 20px 15px 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* ============================
       TITLE
    ============================ */
    h1 {
      font-family: var(--font-pixel);
      font-size: clamp(0.8rem, 3.5vw, 1.1rem);
      color: var(--color-games);
      text-shadow: 0 0 16px rgba(0,245,255,0.6);
      letter-spacing: 0.05em;
      line-height: 1.8;
      text-align: center;
      padding: 12px 10px 22px;
    }

    /* ============================
       DICE AREA
    ============================ */
    #dice-area {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 32px;
      width: 100%;
    }

    .die-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 5px;
    }

    .die {
      width: 78px;
      height: 78px;
      background: linear-gradient(145deg, #fffef8, #f0ead8);
      border-radius: 14px;
      border: 2px solid #ccc0a0;
      box-shadow:
        inset 0 2px 5px rgba(255,255,255,0.9),
        inset 0 -2px 4px rgba(0,0,0,0.08),
        0 6px 14px rgba(0,0,0,0.6),
        0 2px 4px rgba(0,0,0,0.3);
      cursor: pointer;
      display: grid;
      grid-template-areas:
        "tl . tr"
        "ml mc mr"
        "bl . br";
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: 1fr 1fr 1fr;
      padding: 10px;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
      position: relative;
    }

    .die:hover {
      transform: translateY(-3px) scale(1.04);
    }

    .die.held {
      border-color: var(--color-games);
      background: linear-gradient(145deg, #f0ffff, #d8f8ff);
      box-shadow:
        inset 0 2px 5px rgba(255,255,255,0.9),
        0 6px 14px rgba(0,0,0,0.5),
        0 0 18px rgba(0,245,255,0.45),
        0 0 36px rgba(0,245,255,0.18);
    }

    /* Continuous shake while rolling */
    @keyframes diceShake {
      0%   { transform: rotate(0deg)    translateY(0px); }
      15%  { transform: rotate(-16deg)  translateY(-7px); }
      30%  { transform: rotate(13deg)   translateY(-9px); }
      45%  { transform: rotate(-11deg)  translateY(-5px); }
      60%  { transform: rotate(9deg)    translateY(-7px); }
      75%  { transform: rotate(-6deg)   translateY(-3px); }
      90%  { transform: rotate(4deg)    translateY(-2px); }
      100% { transform: rotate(0deg)    translateY(0px); }
    }

    .die.rolling {
      animation: diceShake 0.28s ease-in-out infinite;
      cursor: default;
    }

    /* HELD label under each die */
    .held-label {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      color: var(--color-games);
      letter-spacing: 1px;
      height: 16px;
    }

    /* ============================
       PIP DOTS
    ============================ */
    .pip {
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 35%, #3a3a3a, #111);
      box-shadow: inset 1px 1px 2px rgba(255,255,255,0.1), 0 1px 2px rgba(0,0,0,0.5);
      justify-self: center;
      align-self: center;
    }

    .pip.tl { grid-area: tl; }
    .pip.tr { grid-area: tr; }
    .pip.ml { grid-area: ml; }
    .pip.mc { grid-area: mc; }
    .pip.mr { grid-area: mr; }
    .pip.bl { grid-area: bl; }
    .pip.br { grid-area: br; }

    /* ============================
       CONTROLS ROW
    ============================ */
    #controls {
      display: flex;
      align-items: center;
      gap: 24px;
      margin-bottom: 14px;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }

    #roll-btn {
      padding: 14px 36px;
      font-family: var(--font-pixel);
      font-size: 0.68rem;
      line-height: 1.8;
      letter-spacing: 0.05em;
      background: transparent;
      color: var(--color-games);
      border: 1px solid var(--color-games);
      border-radius: 10px;
      cursor: pointer;
      box-shadow: 0 0 16px rgba(0,245,255,0.15);
      transition: background 0.15s, box-shadow 0.15s, transform 0.08s;
    }

    #roll-btn:hover:not(:disabled) {
      background: rgba(0,245,255,0.08);
      box-shadow: 0 0 28px rgba(0,245,255,0.35);
      transform: translateY(-2px);
    }

    #roll-btn:active:not(:disabled) {
      transform: translateY(2px);
      box-shadow: 0 0 8px rgba(0,245,255,0.1);
    }

    #roll-btn:disabled {
      border-color: var(--color-surface-border);
      color: var(--color-text-muted);
      box-shadow: none;
      cursor: not-allowed;
      opacity: 0.5;
    }

    #info-panel {
      text-align: center;
      line-height: 1.7;
    }

    #rolls-left-display {
      font-family: var(--font-pixel);
      font-size: 0.65rem;
      color: var(--color-games);
      line-height: 1.8;
    }

    #round-display {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--color-text-secondary);
    }

    /* ============================
       STATUS MESSAGE
    ============================ */
    #message {
      min-height: 28px;
      text-align: center;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      font-style: italic;
      color: var(--color-text-secondary);
      margin-bottom: 18px;
      max-width: 480px;
      line-height: 1.5;
      width: 100%;
    }

    /* ============================
       SCORECARD
    ============================ */
    #scorecard {
      width: 100%;
      max-width: 490px;
      background: var(--color-surface-raised);
      border: 1px solid var(--color-surface-border);
      border-radius: 14px;
      overflow: hidden;
    }

    .section-header {
      background: rgba(255,183,0,0.08);
      border-bottom: 1px solid rgba(255,183,0,0.2);
      padding: 8px 16px;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--color-amber);
    }

    .score-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 16px;
      border-bottom: 1px solid var(--color-surface-border);
      transition: background 0.12s;
    }

    .score-row.clickable { cursor: pointer; }
    .score-row.clickable:hover { background: rgba(255,255,255,0.05); }

    /* Pulse when player MUST pick a score */
    @keyframes mustPick {
      0%, 100% { background: rgba(255,183,0,0.03); }
      50%       { background: rgba(255,183,0,0.14); }
    }

    .score-row.must-pick { animation: mustPick 1.1s ease-in-out infinite; }
    .score-row.must-pick:hover { animation: none; background: rgba(255,183,0,0.2) !important; }

    .score-row.used { opacity: 0.5; cursor: default; }

    .score-name {
      font-family: var(--font-sans);
      font-size: 0.88rem;
      color: var(--color-text-primary);
    }

    .score-hint {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--color-text-muted);
      margin-top: 1px;
    }

    .score-value {
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 600;
      min-width: 48px;
      text-align: right;
      color: var(--color-text-secondary);
    }

    .score-value.good  { color: var(--color-games); }
    .score-value.zero  { color: #e07070; }
    .score-value.final { color: var(--color-amber); }

    .info-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 7px 16px;
      border-bottom: 1px solid var(--color-surface-border);
      background: rgba(255,255,255,0.02);
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--color-text-secondary);
    }

    .subtotal-row {
      display: flex;
      justify-content: space-between;
      padding: 9px 16px;
      background: rgba(255,183,0,0.07);
      font-family: var(--font-mono);
      font-size: 1rem;
      font-weight: 700;
      color: var(--color-amber);
      border-bottom: 1px solid rgba(255,183,0,0.12);
    }

    .grand-total-row {
      display: flex;
      justify-content: space-between;
      padding: 13px 16px;
      background: rgba(255,183,0,0.12);
      font-family: var(--font-pixel);
      font-size: 0.75rem;
      line-height: 1.8;
      color: var(--color-amber);
    }

    /* ============================
       GAME OVER OVERLAY
    ============================ */
    #game-over-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.82);
      align-items: center;
      justify-content: center;
      z-index: 200;
    }

    #game-over-overlay.visible { display: flex; }

    #game-over-box {
      background: var(--color-surface-raised);
      border: 2px solid var(--color-amber);
      border-radius: 20px;
      padding: 40px 50px;
      text-align: center;
      box-shadow:
        0 20px 60px rgba(0,0,0,0.7),
        0 0 40px rgba(255,183,0,0.12);
      max-width: 360px;
      width: 92%;
      animation: pop 0.45s cubic-bezier(.36,1.56,.64,1);
    }

    @keyframes pop {
      0%   { transform: scale(0.2) rotate(-8deg); opacity: 0; }
      100% { transform: scale(1)   rotate(0deg);  opacity: 1; }
    }

    #game-over-box h2 {
      font-family: var(--font-pixel);
      font-size: clamp(0.8rem, 4vw, 1.1rem);
      color: var(--color-amber);
      text-shadow: 0 0 20px rgba(255,183,0,0.4);
      line-height: 1.8;
      margin-bottom: 8px;
    }

    #game-over-box p {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--color-text-secondary);
      margin-bottom: 5px;
    }

    #final-score {
      font-family: var(--font-pixel);
      font-size: clamp(2rem, 10vw, 3.5rem);
      color: var(--color-amber);
      margin: 14px 0;
      text-shadow: 0 0 20px rgba(255,183,0,0.3);
      line-height: 1.2;
    }

    #score-comment {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      color: var(--color-text-secondary);
      margin: 10px 0 24px;
    }

    #play-again-btn {
      padding: 14px 32px;
      font-family: var(--font-pixel);
      font-size: 0.65rem;
      line-height: 1.8;
      letter-spacing: 0.05em;
      background: transparent;
      color: var(--color-games);
      border: 1px solid var(--color-games);
      border-radius: 8px;
      cursor: pointer;
      box-shadow: 0 0 16px rgba(0,245,255,0.15);
      transition: background 0.15s, box-shadow 0.15s, transform 0.1s;
    }

    #play-again-btn:hover {
      background: rgba(0,245,255,0.08);
      box-shadow: 0 0 28px rgba(0,245,255,0.35);
      transform: translateY(-2px);
    }

    #play-again-btn:active { transform: translateY(1px); }
  </style>
</head>
<body>

<!-- ── Nav bar ── -->
<nav id="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-word">hoofay</span>
      <span class="logo-tld">.com</span>
    </a>
    <a href="/games" class="back-link">← Web Games</a>
  </div>
</nav>

<div id="page">

  <h1>🎲 YAHTZEE!</h1>

  <!-- Five dice, created by JS -->
  <div id="dice-area"></div>

  <!-- Roll button and round info -->
  <div id="controls">
    <div id="info-panel">
      <div id="rolls-left-display">🎲 3 rolls left</div>
      <div id="round-display">Round 1 of 13</div>
    </div>
    <button id="roll-btn">Roll Dice!</button>
  </div>

  <!-- Status message -->
  <div id="message">Press "Roll Dice!" to start your first turn! 🎲</div>

  <!-- Scorecard -->
  <div id="scorecard">
    <div id="upper-section">
      <div class="section-header">⬆️ Upper Section — score 63+ for a +35 bonus!</div>
    </div>
    <div id="lower-section">
      <div class="section-header">⬇️ Lower Section</div>
    </div>
  </div>

</div><!-- /#page -->

<!-- Game over popup -->
<div id="game-over-overlay">
  <div id="game-over-box">
    <h2>🎉 Game Over!</h2>
    <p>Your final score:</p>
    <div id="final-score">0</div>
    <div id="score-comment"></div>
    <button id="play-again-btn">Play Again! 🎲</button>
  </div>
</div>

<script is:inline>
  // ============================
  // PIP POSITIONS FOR EACH FACE
  // Uses the CSS grid areas: tl, tr, ml, mc, mr, bl, br
  // ============================
  const PIP_MAP = {
    1: ['mc'],
    2: ['tr', 'bl'],
    3: ['tr', 'mc', 'bl'],
    4: ['tl', 'tr', 'bl', 'br'],
    5: ['tl', 'tr', 'mc', 'bl', 'br'],
    6: ['tl', 'tr', 'ml', 'mr', 'bl', 'br'],
  };

  // ============================
  // SCORING CATEGORIES
  // ============================
  const CATEGORIES = [
    // Upper section: add up the matching number
    { id: 'ones',          name: 'Ones',            hint: 'Total of all 1s',         section: 'upper' },
    { id: 'twos',          name: 'Twos',            hint: 'Total of all 2s',         section: 'upper' },
    { id: 'threes',        name: 'Threes',          hint: 'Total of all 3s',         section: 'upper' },
    { id: 'fours',         name: 'Fours',           hint: 'Total of all 4s',         section: 'upper' },
    { id: 'fives',         name: 'Fives',           hint: 'Total of all 5s',         section: 'upper' },
    { id: 'sixes',         name: 'Sixes',           hint: 'Total of all 6s',         section: 'upper' },
    // Lower section: special combos
    { id: 'threeOfAKind',  name: 'Three of a Kind', hint: '3 same → total all dice', section: 'lower' },
    { id: 'fourOfAKind',   name: 'Four of a Kind',  hint: '4 same → total all dice', section: 'lower' },
    { id: 'fullHouse',     name: 'Full House',      hint: '3+2 matching → 25 pts',   section: 'lower' },
    { id: 'smallStraight', name: 'Small Straight',  hint: '4 in a row → 30 pts',     section: 'lower' },
    { id: 'largeStraight', name: 'Large Straight',  hint: '5 in a row → 40 pts',     section: 'lower' },
    { id: 'yahtzee',       name: 'YAHTZEE! ⭐',     hint: 'All 5 the same → 50 pts', section: 'lower' },
    { id: 'chance',        name: 'Chance',          hint: 'Total of all dice',        section: 'lower' },
  ];

  // ============================
  // GAME STATE
  // ============================
  let dice          = [1, 1, 1, 1, 1]; // current face values
  let held          = [false, false, false, false, false]; // which dice are held
  let rollsLeft     = 3;
  let currentRound  = 1;
  let scores        = {};   // categoryId → points (undefined = not yet scored)
  let yahtzeeBonuses = 0;   // extra Yahtzees after the first score 50
  let hasRolled     = false; // rolled at least once this turn?
  let isRolling     = false; // animation playing?

  // ============================
  // SCORE CALCULATOR
  // ============================
  function calcScore(id, d) {
    // Count how many of each face value appear
    const counts = Array(7).fill(0);
    d.forEach(v => counts[v]++);
    const total  = d.reduce((a, b) => a + b, 0);
    const unique = [...new Set(d)].sort((a, b) => a - b); // sorted unique values

    switch (id) {
      case 'ones':   return counts[1] * 1;
      case 'twos':   return counts[2] * 2;
      case 'threes': return counts[3] * 3;
      case 'fours':  return counts[4] * 4;
      case 'fives':  return counts[5] * 5;
      case 'sixes':  return counts[6] * 6;

      case 'threeOfAKind': return counts.some(c => c >= 3) ? total : 0;
      case 'fourOfAKind':  return counts.some(c => c >= 4) ? total : 0;

      case 'fullHouse':
        // Need exactly 3 of one value AND 2 of another
        return (counts.some(c => c === 3) && counts.some(c => c === 2)) ? 25 : 0;

      case 'smallStraight': {
        // Need 4 consecutive values anywhere in the dice
        let run = 1, maxRun = 1;
        for (let i = 1; i < unique.length; i++) {
          if (unique[i] === unique[i - 1] + 1) {
            run++;
            if (run > maxRun) maxRun = run;
          } else if (unique[i] !== unique[i - 1]) {
            run = 1;
          }
        }
        return maxRun >= 4 ? 30 : 0;
      }

      case 'largeStraight': {
        // Need all 5 dice to be consecutive and unique
        if (unique.length < 5) return 0;
        for (let i = 1; i < unique.length; i++) {
          if (unique[i] !== unique[i - 1] + 1) return 0;
        }
        return 40;
      }

      case 'yahtzee': return counts.some(c => c === 5) ? 50 : 0;
      case 'chance':  return total;
    }
    return 0;
  }

  // ============================
  // BUILD DICE IN THE DOM
  // Called once on startup; click handlers stay for the whole game
  // ============================
  function setupDice() {
    const area = document.getElementById('dice-area');
    area.innerHTML = '';
    for (let i = 0; i < 5; i++) {
      const wrapper = document.createElement('div');
      wrapper.className = 'die-wrapper';

      const die = document.createElement('div');
      die.className = 'die';
      die.id = `die-${i}`;
      die.addEventListener('click', () => {
        // Can only hold/unhold after first roll, and if rolls remain
        if (!hasRolled || isRolling || rollsLeft === 0) return;
        held[i] = !held[i];
        refreshDiceFaces();
      });

      const label = document.createElement('div');
      label.className = 'held-label';
      label.id = `held-label-${i}`;

      wrapper.appendChild(die);
      wrapper.appendChild(label);
      area.appendChild(wrapper);
    }
    refreshDiceFaces();
  }

  // Update pip patterns and held styling on all 5 dice.
  // Does NOT touch the 'rolling' CSS class (animation stays active).
  function refreshDiceFaces() {
    for (let i = 0; i < 5; i++) {
      const die   = document.getElementById(`die-${i}`);
      const label = document.getElementById(`held-label-${i}`);
      if (!die) continue;

      // Remove old pips, add new ones for current face value
      die.querySelectorAll('.pip').forEach(p => p.remove());
      (PIP_MAP[dice[i]] || []).forEach(pos => {
        const pip = document.createElement('div');
        pip.className = `pip ${pos}`;
        die.appendChild(pip);
      });

      // Held styling
      die.classList.toggle('held', held[i]);
      label.textContent = held[i] ? '🔒 HELD' : '';
      die.title = held[i] ? 'Click to unhold' : (hasRolled && rollsLeft > 0 ? 'Click to hold' : '');
    }
  }

  // ============================
  // ROLLING ANIMATION
  // ============================
  function doRoll() {
    if (rollsLeft <= 0 || isRolling) return;

    hasRolled = true;
    rollsLeft--;
    isRolling = true;
    document.getElementById('roll-btn').disabled = true;

    // Decide final values NOW (before animation)
    const finalDice = dice.map((v, i) => held[i] ? v : (Math.ceil(Math.random() * 6)));

    // Start shake animation on unheld dice
    for (let i = 0; i < 5; i++) {
      if (!held[i]) document.getElementById(`die-${i}`).classList.add('rolling');
    }

    // Cycle random faces during the shake for visual drama
    let ticks = 0;
    const interval = setInterval(() => {
      ticks++;
      for (let i = 0; i < 5; i++) {
        if (!held[i]) dice[i] = Math.ceil(Math.random() * 6);
      }
      refreshDiceFaces(); // updates pips without touching 'rolling' class

      if (ticks >= 9) {
        clearInterval(interval);
        // Snap to final result
        dice = finalDice;
        refreshDiceFaces();
        // Stop shake animation
        for (let i = 0; i < 5; i++) {
          document.getElementById(`die-${i}`).classList.remove('rolling');
        }
        isRolling = false;
        onRollComplete();
      }
    }, 70); // ~630 ms total
  }

  // Called when the roll animation finishes
  function onRollComplete() {
    // Check for Yahtzee BEFORE rendering scorecard so bonus shows immediately
    const rolledYahtzee = calcScore('yahtzee', dice) === 50;
    if (rolledYahtzee && scores['yahtzee'] === 50) {
      yahtzeeBonuses++;
    }

    updateHeader();
    renderScorecard();

    if (rollsLeft > 0) {
      document.getElementById('roll-btn').disabled = false;
    }

    // Pick a status message
    if (rolledYahtzee) {
      if (scores['yahtzee'] === 50) {
        setMsg('🎉 BONUS YAHTZEE! +100 bonus points! You legend!!!');
      } else if (scores['yahtzee'] === undefined) {
        setMsg('🎲✨ YAHTZEE!! Five of a kind — incredible!!!');
      } else {
        setMsg('Five of a kind! Wow! Now pick a score below.');
      }
    } else if (rollsLeft === 0) {
      setMsg('No rolls left — click a score on the card below! 👇');
    } else if (rollsLeft === 1) {
      setMsg('One roll left! Click the dice you want to keep first.');
    } else {
      setMsg('Click dice to hold them, then roll again!');
    }
  }

  // ============================
  // SCORE A CATEGORY
  // ============================
  function scoreCategory(id) {
    if (scores[id] !== undefined || !hasRolled) return;

    scores[id] = calcScore(id, dice);

    // Reset for next round
    currentRound++;
    hasRolled  = false;
    rollsLeft  = 3;
    held = [false, false, false, false, false];
    refreshDiceFaces();

    if (currentRound > 13) {
      renderScorecard();
      endGame();
      return;
    }

    document.getElementById('roll-btn').disabled = false;
    const catName = CATEGORIES.find(c => c.id === id).name;
    if (scores[id] > 0) {
      setMsg(`Great! Scored ${scores[id]} points in "${catName}"! 🎉 Roll for your next turn.`);
    } else {
      setMsg(`Scored 0 in "${catName}" — tough luck! Roll for your next turn.`);
    }

    updateHeader();
    renderScorecard();
  }

  // ============================
  // UI HELPERS
  // ============================
  function setMsg(text) {
    document.getElementById('message').textContent = text;
  }

  function updateHeader() {
    const rd = document.getElementById('rolls-left-display');
    if (rollsLeft === 0) {
      rd.textContent = '❌ No rolls left';
    } else {
      rd.textContent = `🎲 ${rollsLeft} roll${rollsLeft !== 1 ? 's' : ''} left`;
    }
    document.getElementById('round-display').textContent =
      `Round ${Math.min(currentRound, 13)} of 13`;
  }

  // ============================
  // RENDER SCORECARD
  // ============================
  function renderScorecard() {
    const upperEl = document.getElementById('upper-section');
    const lowerEl = document.getElementById('lower-section');

    // Keep the header row, remove everything else
    const clearSection = el => {
      const hdr = el.firstElementChild;
      el.innerHTML = '';
      el.appendChild(hdr);
    };
    clearSection(upperEl);
    clearSection(lowerEl);

    // --- Upper section rows ---
    let upperRaw = 0;
    CATEGORIES.filter(c => c.section === 'upper').forEach(cat => {
      upperEl.appendChild(buildScoreRow(cat));
      if (scores[cat.id] !== undefined) upperRaw += scores[cat.id];
    });

    // Bonus progress
    const bonusEarned = upperRaw >= 63;
    const bonusRow = document.createElement('div');
    bonusRow.className = 'info-row';
    bonusRow.innerHTML = `
      <span>+35 Bonus ${bonusEarned ? '✅ Earned!' : `— need ${63 - upperRaw} more`}</span>
      <span>${bonusEarned ? '+35' : `${upperRaw}/63`}</span>
    `;
    upperEl.appendChild(bonusRow);

    const upperTotal = upperRaw + (bonusEarned ? 35 : 0);
    const upperSub = document.createElement('div');
    upperSub.className = 'subtotal-row';
    upperSub.innerHTML = `<span>Upper Total</span><span>${upperTotal}</span>`;
    upperEl.appendChild(upperSub);

    // --- Lower section rows ---
    let lowerRaw = 0;
    CATEGORIES.filter(c => c.section === 'lower').forEach(cat => {
      lowerEl.appendChild(buildScoreRow(cat));
      if (scores[cat.id] !== undefined) lowerRaw += scores[cat.id];
    });

    // Yahtzee bonus row (if any bonus Yahtzees were rolled)
    if (yahtzeeBonuses > 0) {
      const ybRow = document.createElement('div');
      ybRow.className = 'info-row';
      ybRow.innerHTML = `
        <span>⭐ Yahtzee Bonus ×${yahtzeeBonuses}</span>
        <span>+${yahtzeeBonuses * 100}</span>
      `;
      lowerEl.appendChild(ybRow);
      lowerRaw += yahtzeeBonuses * 100;
    }

    const lowerSub = document.createElement('div');
    lowerSub.className = 'subtotal-row';
    lowerSub.innerHTML = `<span>Lower Total</span><span>${lowerRaw}</span>`;
    lowerEl.appendChild(lowerSub);

    // Grand total
    const grand = upperTotal + lowerRaw;
    const grandRow = document.createElement('div');
    grandRow.className = 'grand-total-row';
    grandRow.innerHTML = `<span>🏆 Grand Total</span><span>${grand}</span>`;
    lowerEl.appendChild(grandRow);
  }

  // Build one row of the scorecard
  function buildScoreRow(cat) {
    const isUsed  = scores[cat.id] !== undefined;
    const canPick = hasRolled && !isUsed;
    const mustPick = canPick && rollsLeft === 0;

    const row = document.createElement('div');
    row.className = 'score-row';
    if (isUsed)   row.classList.add('used');
    if (canPick)  row.classList.add('clickable');
    if (mustPick) row.classList.add('must-pick');

    if (canPick) row.addEventListener('click', () => scoreCategory(cat.id));

    // Name and hint text
    const nameCol = document.createElement('div');
    const nameDiv = document.createElement('div');
    nameDiv.className = 'score-name';
    nameDiv.textContent = cat.name;
    const hintDiv = document.createElement('div');
    hintDiv.className = 'score-hint';
    hintDiv.textContent = cat.hint;
    nameCol.appendChild(nameDiv);
    nameCol.appendChild(hintDiv);

    // Score value (final, preview, or blank)
    const valEl = document.createElement('div');
    valEl.className = 'score-value';
    if (isUsed) {
      valEl.textContent = scores[cat.id];
      valEl.classList.add('final');
    } else if (hasRolled) {
      const preview = calcScore(cat.id, dice);
      valEl.textContent = preview > 0 ? `+${preview}` : '0';
      valEl.classList.add(preview > 0 ? 'good' : 'zero');
    } else {
      valEl.textContent = '—';
    }

    row.appendChild(nameCol);
    row.appendChild(valEl);
    return row;
  }

  // ============================
  // END GAME
  // ============================
  function endGame() {
    let upperRaw = 0, lowerRaw = 0;
    CATEGORIES.forEach(cat => {
      const s = scores[cat.id] || 0;
      if (cat.section === 'upper') upperRaw += s;
      else lowerRaw += s;
    });
    const bonus  = upperRaw >= 63 ? 35 : 0;
    const yahBonus = yahtzeeBonuses * 100;
    const grand  = upperRaw + bonus + lowerRaw + yahBonus;

    document.getElementById('final-score').textContent = grand;

    let comment;
    if      (grand >= 300) comment = '🏆 LEGENDARY score! You\'re a Yahtzee master!';
    else if (grand >= 250) comment = '⭐ Fantastic! Seriously impressive rolling!';
    else if (grand >= 200) comment = '😄 Great score! You\'re getting really good!';
    else if (grand >= 150) comment = '👍 Nice work! Play again to beat it!';
    else                   comment = '🎮 Good try! Every game you get better!';

    document.getElementById('score-comment').textContent = comment;
    document.getElementById('game-over-overlay').classList.add('visible');
  }

  // ============================
  // PLAY AGAIN
  // ============================
  function resetGame() {
    dice           = [1, 1, 1, 1, 1];
    held           = [false, false, false, false, false];
    rollsLeft      = 3;
    currentRound   = 1;
    scores         = {};
    yahtzeeBonuses = 0;
    hasRolled      = false;
    isRolling      = false;

    document.getElementById('game-over-overlay').classList.remove('visible');
    document.getElementById('roll-btn').disabled = false;
    setMsg('Press "Roll Dice!" to start your first turn! 🎲');
    updateHeader();
    refreshDiceFaces();
    renderScorecard();
  }

  // ============================
  // WIRE UP BUTTONS & START
  // ============================
  document.getElementById('roll-btn').addEventListener('click', doRoll);
  document.getElementById('play-again-btn').addEventListener('click', resetGame);

  setupDice();
  renderScorecard();
  updateHeader();
</script>
</body>
</html>

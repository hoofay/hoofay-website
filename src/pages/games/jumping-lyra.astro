---
// Standalone game page — embeds the itch.io HTML5 game in an iframe.
// SETUP: In your itch.io dashboard → Edit "Jumping Lyra" → Embed options
//        → tick "Embeddable in browser" → copy the iframe src URL and
//        paste it into the EMBED_SRC constant below.
const EMBED_SRC = "https://itch.io/embed-upload/3173206?color=333333";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jumping Lyra | hoofay.com</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --color-games:          #00F5FF;
      --color-surface:        #0A0A0F;
      --color-surface-raised: #12121A;
      --color-surface-card:   #1A1A26;
      --color-surface-border: #2A2A3D;
      --color-text-primary:   #F0F0FF;
      --color-text-secondary: #9090B0;
      --color-text-muted:     #505070;
      --font-sans:  'Inter', system-ui, sans-serif;
      --font-pixel: 'Press Start 2P', monospace;
      --font-mono:  'JetBrains Mono', 'Fira Code', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
    }

    body {
      background-color: var(--color-surface);
      color: var(--color-text-primary);
      font-family: var(--font-sans);
      display: flex;
      flex-direction: column;
    }

    /* Subtle grid overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(42,42,61,0.35) 1px, transparent 1px),
        linear-gradient(90deg, rgba(42,42,61,0.35) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0;
    }

    body > * { position: relative; z-index: 1; }

    /* ── Nav bar ── */
    #site-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      width: 100%;
      border-bottom: 1px solid var(--color-surface-border);
      background: rgba(10,10,15,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      flex-shrink: 0;
    }

    #site-nav .nav-inner {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    #site-nav .logo {
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
    }

    #site-nav .logo-word {
      font-family: var(--font-pixel);
      font-size: 0.75rem;
      color: var(--color-games);
      text-shadow: 0 0 12px rgba(0,245,255,0.6);
      letter-spacing: 0.05em;
      line-height: 1.6;
      animation: flicker 4s linear infinite;
    }

    #site-nav .logo-tld {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--color-text-muted);
    }

    #site-nav .back-link {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--color-text-secondary);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 6px;
      border: 1px solid transparent;
      transition: color 0.2s, border-color 0.2s;
    }

    #site-nav .back-link:hover {
      color: var(--color-games);
      border-color: rgba(0,245,255,0.3);
    }

    @keyframes flicker {
      0%, 95%, 100% { opacity: 1; }
      96%           { opacity: 0.8; }
      97%           { opacity: 1; }
      98%           { opacity: 0.6; }
      99%           { opacity: 1; }
    }

    /* ── Game area ── */
    #game-wrap {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      gap: 16px;
    }

    .game-title {
      font-family: var(--font-pixel);
      font-size: clamp(0.75rem, 3vw, 1rem);
      color: var(--color-games);
      text-shadow: 0 0 16px rgba(0,245,255,0.6);
      letter-spacing: 0.05em;
      text-align: center;
      line-height: 1.8;
    }

    /* iframe container — scales down on small screens */
    .game-frame-wrap {
      width: 100%;
      max-width: 640px;
      aspect-ratio: 640 / 360;
      border: 1px solid var(--color-surface-border);
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 0 40px rgba(0,245,255,0.08), 0 8px 32px rgba(0,0,0,0.6);
    }

    .game-frame-wrap iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    .game-meta {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--color-text-muted);
      text-align: center;
      line-height: 1.7;
    }

    .game-meta a {
      color: var(--color-text-secondary);
      text-decoration: none;
      border-bottom: 1px solid rgba(144,144,176,0.3);
      transition: color 0.2s, border-color 0.2s;
    }

    .game-meta a:hover {
      color: var(--color-games);
      border-color: rgba(0,245,255,0.4);
    }
  </style>
</head>
<body>

<nav id="site-nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      <span class="logo-word">hoofay</span>
      <span class="logo-tld">.com</span>
    </a>
    <a href="/games" class="back-link">← Web Games</a>
  </div>
</nav>

<div id="game-wrap">
  <div class="game-title">Jumping Lyra</div>

  <div class="game-frame-wrap">
    <iframe
      src={EMBED_SRC}
      allowfullscreen
      allow="autoplay; fullscreen *"
      scrolling="no"
    ></iframe>
  </div>

  <p class="game-meta">
    Made with love, years ago. ·
    <a href="https://hoofay.itch.io/jumping-lyra" target="_blank" rel="noopener">
      View on itch.io ↗
    </a>
  </p>
</div>

</body>
</html>

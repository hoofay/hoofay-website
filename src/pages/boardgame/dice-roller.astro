---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Dice Roller" description="Roll any combination of dice — d4, d6, d8, d10, d12, d20." section="boardgame">

<style is:global>
  .die-canvas-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .die-canvas-wrap canvas {
    width: 70px !important;
    height: 70px !important;
    border-radius: 6px;
    display: block;
  }
  .die-canvas-wrap canvas.landed {
    filter: drop-shadow(0 0 10px rgba(255, 183, 0, 0.8));
  }
  .die-result-overlay {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.4rem;
    font-weight: 700;
    color: #FFB700;
    text-shadow: 0 0 8px rgba(255, 183, 0, 0.9), 0 0 2px #000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .die-result-overlay.visible {
    opacity: 1;
  }
</style>

  <main class="max-w-2xl mx-auto px-6 py-12">
    <a href="/boardgame" class="text-boardgame text-sm font-mono hover:opacity-80 transition-opacity mb-8 inline-block">← back</a>

    <h1 class="pixel-heading text-xl text-boardgame glow-amber mb-2">Dice Roller</h1>
    <p class="text-text-secondary mb-10">Tap a die to add it to your roll. Hit <strong class="text-text-primary">Roll!</strong> when ready.</p>

    <!-- Die selector -->
    <div class="flex flex-wrap gap-3 mb-8" id="die-selector">
      {['d4','d6','d8','d10','d12','d20','d100'].map(die => (
        <button
          data-die={die}
          class="die-btn px-4 py-2 rounded-lg border border-boardgame/40 bg-boardgame/10 text-boardgame font-mono font-bold hover:bg-boardgame/20 hover:border-boardgame/70 transition-all active:scale-95"
        >
          {die}
        </button>
      ))}
    </div>

    <!-- Selected dice -->
    <div id="selected" class="min-h-12 mb-6 flex flex-wrap gap-2 items-center">
      <span id="selected-empty" class="text-text-muted text-sm font-mono">No dice selected yet…</span>
    </div>

    <!-- Roll button -->
    <div class="flex gap-3 mb-10">
      <button
        id="roll-btn"
        class="px-8 py-3 rounded-lg bg-boardgame text-surface font-bold text-lg hover:opacity-90 active:scale-95 transition-all box-glow-amber disabled:opacity-40"
        disabled
      >
        Roll!
      </button>
      <button
        id="clear-btn"
        class="px-4 py-3 rounded-lg border border-surface-border text-text-secondary hover:text-text-primary hover:border-surface-border/80 transition-all font-mono text-sm"
      >
        Clear
      </button>
    </div>

    <!-- Results -->
    <div id="results" class="hidden">
      <div class="border border-boardgame/30 bg-boardgame/5 rounded-xl p-6">
        <h2 class="text-text-muted text-xs font-mono uppercase tracking-widest mb-6">Rolling…</h2>
        <div id="result-dice" class="flex flex-wrap gap-3 mb-6 items-end"></div>
        <div id="total-row" class="border-t border-surface-border pt-4 flex items-baseline gap-3 hidden">
          <span class="text-text-secondary font-mono text-sm">Total:</span>
          <span id="result-total" class="text-4xl font-bold text-boardgame glow-amber transition-transform"></span>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script type="module">
// ── PART 1: Three.js import ───────────────────────────────
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.min.js';
// ── PART 2: Geometry helpers ──────────────────────────────

// Custom d10: pentagonal trapezohedron using indexed BufferGeometry
// Flat kite faces — no vertex normalisation (avoids PolyhedronGeometry distortion)
function buildD10Geometry() {
  const H = 1.1, h = 0.3, r = 0.95;
  // 12 verts: 0=top, 1=bottom, 2-6=upper ring, 7-11=lower ring
  const pos = [0,H,0,  0,-H,0];
  for (let i = 0; i < 5; i++) {
    const a = i * Math.PI * 2 / 5;
    pos.push(Math.cos(a)*r, h, Math.sin(a)*r);
  }
  for (let i = 0; i < 5; i++) {
    const a = i * Math.PI * 2 / 5 + Math.PI / 5;
    pos.push(Math.cos(a)*r, -h, Math.sin(a)*r);
  }
  const idx = [];
  for (let i = 0; i < 5; i++) {
    const u0=2+i, u1=2+(i+1)%5, l0=7+i, l1=7+(i+1)%5;
    idx.push(0,l0,u0,  0,u1,l0);  // upper kite
    idx.push(1,l0,u1,  1,u1,l1);  // lower kite
  }
  const geo = new THREE.BufferGeometry();
  geo.setIndex(idx);
  geo.setAttribute('position', new THREE.Float32BufferAttribute(pos, 3));
  geo.computeVertexNormals();
  return geo;
}

// Single solid material — DoubleSide so winding order never hides a face
const FACE_MAT = new THREE.MeshStandardMaterial({ color: 0x1a1a2e, roughness: 0.5, metalness: 0.2, side: THREE.DoubleSide });

// After tumbling, find which face normal is closest to +Z (camera) and
// return a quaternion that snaps it exactly onto +Z
function snapToFace(mesh) {
  const normals = mesh.geometry.attributes.normal;
  let bestDot = -Infinity;
  let bestLocal = new THREE.Vector3(0, 0, 1);
  const tmp = new THREE.Vector3();
  for (let i = 0; i < normals.count; i++) {
    tmp.fromBufferAttribute(normals, i).applyQuaternion(mesh.quaternion);
    if (tmp.z > bestDot) {
      bestDot = tmp.z;
      bestLocal.fromBufferAttribute(normals, i).normalize();
    }
  }
  return new THREE.Quaternion().setFromUnitVectors(bestLocal, new THREE.Vector3(0, 0, 1));
}
// ── PART 3: Scene setup + animation ──────────────────────

function getDieGeo(die) {
  if (die === 'd4')   return new THREE.TetrahedronGeometry(1.1);
  if (die === 'd6')   return new THREE.BoxGeometry(1.5, 1.5, 1.5);
  if (die === 'd8')   return new THREE.OctahedronGeometry(1.2);
  if (die === 'd10')  return buildD10Geometry();
  if (die === 'd12')  return new THREE.DodecahedronGeometry(1.1);
  if (die === 'd20')  return new THREE.IcosahedronGeometry(1.3);
  /* d100 */          return new THREE.SphereGeometry(1.1, 24, 16);
}

// Returns { canvas, promise }
function createDieScene(die, delay) {
  const canvas = document.createElement('canvas');
  canvas.width = canvas.height = 140;

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setSize(140, 140, false); // false = don't override CSS size
  renderer.setPixelRatio(1);

  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
  camera.position.set(0, 0, 4);

  scene.add(new THREE.AmbientLight(0xffffff, 1.0));
  const pt = new THREE.PointLight(0xffd580, 1.2, 20);
  pt.position.set(3, 4, 3);
  scene.add(pt);

  const mesh = new THREE.Mesh(getDieGeo(die), FACE_MAT);
  scene.add(mesh);

  mesh.rotation.set(
    Math.random() * Math.PI * 2,
    Math.random() * Math.PI * 2,
    Math.random() * Math.PI * 2
  );

  let rafId;
  const startTime      = performance.now() + delay;
  const spinDuration   = 700;
  const settleDuration = 350;
  let settleStart = null, settleFrom = null, settleTo = null;

  const promise = new Promise(resolve => {
    function tick(now) {
      const t = now - startTime;

      if (t < 0) {
        renderer.render(scene, camera);
        rafId = requestAnimationFrame(tick);
        return;
      }

      if (t < spinDuration) {
        mesh.rotation.x += 0.06;
        mesh.rotation.y += 0.05;
        renderer.render(scene, camera);
        rafId = requestAnimationFrame(tick);
        return;
      }

      // Settling phase
      if (!settleStart) {
        settleStart = now;
        settleFrom  = mesh.quaternion.clone();
        settleTo    = snapToFace(mesh);
      }
      const s = Math.min((now - settleStart) / settleDuration, 1);
      mesh.quaternion.slerpQuaternions(settleFrom, settleTo, s);
      renderer.render(scene, camera);

      if (s < 1) {
        rafId = requestAnimationFrame(tick);
      } else {
        cancelAnimationFrame(rafId);
        canvas.classList.add('landed');
        resolve();
      }
    }
    rafId = requestAnimationFrame(tick);
  });

  return { canvas, promise };
}
// ── PART 4: UI logic ─────────────────────────────────────

const selected     = [];
const selectedEl   = document.getElementById('selected');
const emptyEl      = document.getElementById('selected-empty');
const rollBtn      = document.getElementById('roll-btn');
const clearBtn     = document.getElementById('clear-btn');
const resultsEl    = document.getElementById('results');
const resultDiceEl = document.getElementById('result-dice');
const totalEl      = document.getElementById('result-total');
const totalRow     = document.getElementById('total-row');
const resultsHead  = resultsEl.querySelector('h2');

function getSides(die) {
  return parseInt(die.slice(1)); // d100 → 100
}
function rollDie(sides) {
  return Math.floor(Math.random() * sides) + 1;
}

function renderSelected() {
  selectedEl.querySelectorAll('.die-chip').forEach(c => c.remove());
  if (selected.length === 0) {
    emptyEl.classList.remove('hidden');
    rollBtn.disabled = true;
  } else {
    emptyEl.classList.add('hidden');
    rollBtn.disabled = false;
    selected.forEach((item, i) => {
      const chip = document.createElement('span');
      chip.className = 'die-chip flex items-center gap-1 px-3 py-1.5 rounded-lg bg-boardgame/20 border border-boardgame/50 text-boardgame font-mono text-sm cursor-pointer hover:bg-red-500/20 hover:border-red-500/50 hover:text-red-400 transition-all';
      chip.textContent = item.die;
      chip.title = 'Click to remove';
      chip.addEventListener('click', () => {
        selected.splice(i, 1);
        renderSelected();
        resultsEl.classList.add('hidden');
      });
      selectedEl.appendChild(chip);
    });
  }
}

document.getElementById('die-selector').addEventListener('click', e => {
  const btn = e.target.closest('[data-die]');
  if (!btn) return;
  selected.push({ die: btn.dataset.die, sides: getSides(btn.dataset.die) });
  renderSelected();
  resultsEl.classList.add('hidden');
});

rollBtn.addEventListener('click', () => {
  const rolls = selected.map(item => ({
    die:    item.die,
    result: rollDie(item.sides),
  }));
  const total = rolls.reduce((sum, r) => sum + r.result, 0);

  resultDiceEl.innerHTML = '';
  totalRow.classList.add('hidden');
  resultsHead.textContent = 'Rolling…';
  resultsEl.classList.remove('hidden');
  rollBtn.disabled = true;

  const promises = rolls.map((r, i) => {
    const wrap = document.createElement('div');
    wrap.className = 'die-canvas-wrap';

    const numEl = document.createElement('span');
    numEl.className = 'die-result-overlay';
    numEl.textContent = String(r.result);

    const label = document.createElement('span');
    label.className = 'text-xs text-text-muted font-mono';
    label.textContent = r.die;

    const { canvas, promise } = createDieScene(r.die, i * 80);
    wrap.appendChild(canvas);
    wrap.appendChild(numEl);
    wrap.appendChild(label);
    resultDiceEl.appendChild(wrap);

    return promise.then(() => { numEl.classList.add('visible'); });
  });

  Promise.all(promises).then(() => {
    resultsHead.textContent = 'Results';
    totalEl.textContent     = String(total);
    totalRow.classList.remove('hidden');
    totalEl.style.transform = 'scale(1.15)';
    setTimeout(() => { totalEl.style.transform = ''; }, 200);
    rollBtn.disabled = false;
  });
});

clearBtn.addEventListener('click', () => {
  selected.length = 0;
  renderSelected();
  resultsEl.classList.add('hidden');
});
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <main class="max-w-xl mx-auto px-6 py-32 text-center">
    <p class="pixel-heading text-6xl text-games glow-cyan animate-flicker mb-6">404</p>
    <h1 class="text-2xl font-bold text-text-primary mb-3">GAME OVER</h1>
    <p class="text-text-secondary mb-10">That page doesn't exist. Maybe it's a secret level?</p>
    <a href="/" class="px-6 py-3 rounded-lg bg-games/10 text-games border border-games/40 hover:bg-games/20 transition-all font-medium">
      ← Back to home
    </a>
  </main>
</BaseLayout>

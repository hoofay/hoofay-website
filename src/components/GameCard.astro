---
interface Props {
  href: string;
  title: string;
  description: string;
  tags?: string[];
  thumbnail?: string;  // path to image in /public
  new?: boolean;
}

const { href, title, description, tags = [], thumbnail, new: isNew = false } = Astro.props;
---

<a
  href={href}
  class="card block overflow-hidden border-surface-border hover:border-games/50 hover:box-glow-cyan group transition-all duration-300"
>
  <!-- Thumbnail -->
  {thumbnail ? (
    <div class="aspect-video overflow-hidden bg-surface-raised">
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-video bg-surface-raised flex items-center justify-center">
      <span class="font-mono text-xs text-text-muted tracking-widest uppercase">play</span>
    </div>
  )}

  <!-- Info -->
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-bold text-text-primary group-hover:text-games transition-colors">{title}</h3>
      {isNew && <span class="tag bg-games/10 text-games border border-games/30 shrink-0">new</span>}
    </div>
    <p class="text-text-secondary text-sm leading-relaxed mb-3">{description}</p>
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {tags.map(tag => (
          <span class="tag bg-surface-raised border border-surface-border text-text-muted">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>
